# =====================================================
# RiskLens Platform Environment Configuration
# =====================================================

# Server Port Configuration
SERVER_PORT=8080

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=risklens
DB_USERNAME=risklens
DB_PASSWORD=risklens123

# JWT Security Configurations
# Secret must be a minimum of 256 bits (32 characters)
JWT_SECRET=RiskLensSecretKeyForJWTTokenGenerationMustBeAtLeast256BitsLong2024
JWT_ACCESS_EXPIRATION=900000
# 7 days in milliseconds
JWT_REFRESH_EXPIRATION=604800000

# CORS Allowed Origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
